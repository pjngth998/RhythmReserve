@startuml

skinparam style strictuml
skinparam sequenceMessageAlign center

actor "Customer" as actor
participant "ReserveSystem" as system
participant "Branch" as branch
participant "Customer" as customer
participant "Room" as room
participant "StockEquipment" as stock
participant "Equipment" as eq
' participant "Booking" as booking
' participant "Service_IN" as sv_in
' participant "TimeSlot" as timeslot

actor -> system : select_eq(customer_id,branch_id,room_id,eq_list)
activate system
loop search_customer(customer_id)
    system -> customer : get_customer_info(customer_id)    
    activate customer
    customer --> system : Customer
    deactivate customer
end
loop search_branch(branch_id)
    system -> branch : get_room_quota(room_id)
    activate branch
    loop search_room(room_id)
                branch -> room : get_eq_quota(room_id)
                activate room
                room --> branch : eq_quota_max
                deactivate room
    end
    branch --> system : eq_quota_max
end
deactivate branch
loop for eq_id in eq_list
    system -> branch : check_stock_eq(eq_id)
    activate branch
    branch -> stock : check_eq(eq_id)
    activate stock

    ' stock -> eq : get_eq(eq_id)
    ' activate eq
    ' eq --> stock : Equipment
    ' deactivate eq
    
    alt have in stock
        stock --> branch : Have Equipment in Stock
        ' deactivate stock
        branch --> system : Can Reserve
        loop for eq_id in eq_list
            ' system -> branch : calculate_quota
            system -> stock : get_size_eq(eq_id)
            ' activate stock
            loop for eq in equipment_list
                stock -> eq : verify_eq(eq_id)
                alt eq.eq_id == self.eq_id
                    eq --> stock : MATCH
                    stock -> eq : get_size(eq_id)
                    eq --> stock : size
                else
                    eq --> stock : NOT MACH
                end
            end
            activate eq
            deactivate eq
            stock --> system : size
        end
        system -> system : total_requested_size += size
    else stock not enough
        stock --> branch : Don't have Equipment in Stock
        deactivate stock
        branch --> system : Not Enough for Reserve
    end
    deactivate branch
end

alt total_requested_size <= quota_eq_max
    system --> actor : Can Reserve Equipment - Add to Booking Successfully
else total_requested_size > quota_eq_max
    system --> actor : Exceed Room Quota Limit
end

deactivate system

@enduml