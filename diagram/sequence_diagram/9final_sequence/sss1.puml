@startuml
title SD-06: add_product_to_service_out (CUS Method Focus)

' --- การตั้งค่าเพื่อความสวยงามและพอดีขอบ ---
skinparam Style strictuml
skinparam MaxMessageSize 200
skinparam sequence {
    MessageAlignment center
    ParticipantPadding 20
}

actor Customer as C
participant "RhythmReserve" as RR
participant "Customer" as CUS
participant "Booking" as BK
participant "Branch" as BR
participant "StockProduct" as STCK
participant "ServiceOUT" as SOUT

C -> RR : add_product_to_service_out(...)
activate RR

' --- 1. เตรียมข้อมูล Object จาก Customer ---
RR -> RR : get_branch_by_id(branch_id)
RR -> RR : get_customer_by_id(customer_id)

' เรียกหา Reserve จาก Customer
RR -> CUS : get_reserve(reserve_id)
activate CUS
CUS -->> RR : reserve
deactivate CUS

' เรียกหา Booking จาก Customer (อยู่คลาสเดียวกัน)
RR -> CUS : find_booking(booking_id)
activate CUS
CUS -->> RR : booking
deactivate CUS

' ดึงถังเก็บค่าบริการจาก Booking
RR -> BK : get_service_out()
activate BK
BK -->> RR : service_out
deactivate BK

' --- 2. ค้นหา Stock (ดึงรายการมาครั้งเดียวตามโค้ด) ---
RR -> BR : branch.product
activate BR
BR -->> RR : stock_list
deactivate BR

loop for each s in stock_list
    alt s.type == product_type
        RR -> RR : stock = s (found)
    end
end

' --- 3. ตรวจสอบเงื่อนไขและจัดการสินค้า ---
alt stock is None
    RR --[#red]> C : Exception("Product type not found")
else len(stock.get_stock) < amount
    RR --[#red]> C : Exception("Not enough stock")
else [Available]
    
    loop i in range(amount)
        RR -> STCK : get_stock[0]
        activate STCK
        STCK -->> RR : product
        deactivate STCK

        RR -> SOUT : add_product(product)
        activate SOUT
        SOUT -->> RR : void
        deactivate SOUT

        RR -> STCK : del_stock(product.id)
        activate STCK
        STCK -->> RR : void
        deactivate STCK
    end

    RR -> SOUT : calculate_total_price()
    activate SOUT
    SOUT -->> RR : total_price
    deactivate SOUT

    RR -->> C : { sout_id, products, total_price }
end

deactivate RR
@enduml