@startuml
title SD-04: cancel_booking (Refined Logic)

skinparam Style strictuml
skinparam sequence {
    MessageAlignment center
}

actor Customer as C
participant "RhythmReserve" as RR
participant "Customer" as CUS
participant "ServiceIN" as SIN
participant "Policy" as POL
participant "PaymentServiceIn" as PSIN
participant "Booking" as BK
participant "Room/Eq" as RE

C -> RR : cancel_booking(customer_id, servicein_id, booking_id, cancel_time, policy)
activate RR

    RR -> RR : get_customer_by_id(customer_id)
    RR -> CUS : get_reserve(servicein_id)
    CUS -->> RR : service_in

    ' เช็คสถานะการจ่ายเงิน
    alt [service_in.status != PAID]
        RR --[#red]> C : raise Exception("Cannot refund...")
    else [status == PAID]
        RR -> SIN : search_booking(booking_id)
        SIN -->> RR : booking

        ' การเช็ค Policy (ยุบให้คลีนเหมือนคูปอง)
        RR -> POL : check_cancel_refund(customer, cancel_time, booking_start)
        activate POL
            POL -> CUS : get_cancellation_limit_hours()
            CUS -->> POL : limit_hours
            POL -->> RR : boolean (check_cancel)
        deactivate POL

        alt [not check_cancel]
            RR --[#red]> C : raise Exception("Cancel too late...")
        else [check_cancel is True]
            
            ' เริ่มกระบวนการ cancel_b ภายใน ServiceIN
            RR -> SIN : cancel_b(booking_id)
            activate SIN
                SIN -> SIN : _calculate_refund(booking)
                
                SIN -> PSIN : payment_refund(refund_amount)
                activate PSIN
                    note over PSIN : Lookup txn & Process Refund
                    PSIN -->> SIN : True
                deactivate PSIN

                SIN -> BK : booking_cancel()
                activate BK
                    BK -> RE : room.update_timeslot_status(..., AVAILABLE)
                    loop for each eq in eq_list
                        BK -> RE : eq.update_timeslot_status(..., AVAILABLE)
                    end
                    BK -->> SIN : True
                deactivate BK

                SIN -> SIN : remove_booking(booking_id)
                SIN -->> RR : True
            deactivate SIN

            RR -->> C : "Cancel Booking Successfully"
        end
    end
deactivate RR
@enduml