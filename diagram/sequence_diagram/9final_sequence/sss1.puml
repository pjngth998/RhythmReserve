@startuml
title SD-06: add_product_to_service_out (Object Navigation Version)

skinparam Style strictuml
skinparam MaxMessageSize 200
skinparam sequence {
    MessageAlignment center
    ParticipantPadding 20
}

actor Customer as C
participant "RhythmReserve" as RR
participant "Customer" as CUS
participant "Reserve" as RSV
participant "Booking" as BK
participant "Branch" as BR
participant "StockProduct" as STCK
participant "ServiceOUT" as SOUT

C -> RR : add_product_to_service_out(..., product_type, amount)
activate RR

' --- จุดที่แก้: การเข้าถึง Object ตามลำดับชั้น ---
RR -> RR : get_branch_by_id(branch_id)
RR -> RR : get_customer_by_id(customer_id)

RR -> CUS : get_reserve(reserve_id)
activate CUS
CUS -->> RR : reserve
deactivate CUS

RR -> RSV : get_booking(booking_id)
activate RSV
RSV -->> RR : booking
deactivate RSV

RR -> BK : service_out
activate BK
BK -->> RR : service_out
deactivate BK

' --- ค้นหา Stock ---
RR -> BR : branch.product (get list)
BR -->> RR : stock_list

loop for each s in stock_list
    alt s.type == product_type
        RR -> RR : stock = s (found)
    end
end

' --- ตรวจสอบ Exception (ยุบรวมให้พอดีขอบ) ---
alt stock is None
    RR --[#red]> C : raise Exception("Product type not found")
else len(stock.get_stock) < amount
    RR --[#red]> C : raise Exception("Not enough stock")
else [Available]
    
    ' --- วนลูปจัดการสินค้าตามโค้ด ---
    loop i in range(amount)
        RR -> STCK : get_stock[0]
        STCK -->> RR : product

        RR -> SOUT : add_product(product)
        activate SOUT
        SOUT -->> RR : void
        deactivate SOUT

        RR -> STCK : del_stock(product.id)
        activate STCK
        STCK -->> RR : void
        deactivate STCK
    end

    ' สรุปผลตอนท้าย
    RR -> SOUT : calculate_total_price()
    activate SOUT
    SOUT -->> RR : total_price
    deactivate SOUT

    RR -->> C : { sout_id, products, total_price }
end

deactivate RR
@enduml