@startuml
title SD-03: pay_service_in (Final Refined)

skinparam Style strictuml
skinparam sequence {
    MessageAlignment center
    ActivationBackgroundColor #E1F5FE
}

actor Customer as C
participant "RhythmReserve" as RR
participant "CustomerInstance" as CI
participant "Membership" as MEM
participant "ServiceIN" as SIN
participant "PaymentServiceIn" as PSIN
participant "Coupon" as CPN
participant "Room/Equipment" as RE

C -> RR : pay_service_in(...)
activate RR

    RR -> RR : get_customer_by_id(customer_id)
    RR -> CI : get_reserve(reserve_id)
    CI -->> RR : service_in

    opt coupon_id is not None
        RR -> CI : get_coupon(coupon_id)
        CI -->> RR : coupon
    end

    RR -> SIN : calculate_total()
    SIN -->> RR : total_price

    '--- จังหวะสร้าง Payment และการดึง Membership ---
    create PSIN
    RR -> PSIN : <<create>> PaymentServiceIn(..., customer, ...)
    activate PSIN
        PSIN -> PSIN : __apply_discount(total, coupon)
        activate PSIN #LightBlue
            
            '--- ขั้นตอนการไปเอา Membership ตามที่คุณแนะนำ ---
            PSIN -> CI : get_membership()
            activate CI
            CI -->> PSIN : membership_instance
            deactivate CI
            
            PSIN -> MEM : get_discount()
            activate MEM
            MEM -->> PSIN : discount_rate
            deactivate MEM
            
            opt coupon is not None
                PSIN -> CPN : validate & get_discount()
                CPN -->> PSIN : coupon_discount
            end
        deactivate PSIN
    PSIN -->> RR : payment instance
    deactivate PSIN

    RR -> SIN : set_payment(payment)
    RR -> SIN : set_final_price(payment.final_price)

    '--- ส่วน Checkout และการ Update Status ---
    RR -> SIN : checkout()
    activate SIN
        SIN -> PSIN : process_payment()
        SIN -->> RR : True (Success)
    deactivate SIN

    alt if checkout is True
        loop for each booking in service_in
            RR -> RE : room.update_timeslot_status(..., RESERVED)
            loop for each eq in booking.eq_list
                RR -> RE : eq.update_timeslot_status(..., RESERVED)
            end
        end
        RR -> RR : _auto_redeem_coupon(customer)
    end

RR -->> C : service_in object
deactivate RR

@enduml