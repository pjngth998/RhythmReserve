'--- สร้าง Booking Object ---
RR -> BK : <<create>> Booking(branch.name, room, selected_eqs, customer, room_slot)
activate BK
BK --> RR : Booking
deactivate BK

opt if addon_types
     loop all addon in list
          RR -> BK : add_addon(Addon_instance)
     end
end

