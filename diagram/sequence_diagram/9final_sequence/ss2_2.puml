    '--- กลับมาที่ create_service_in ---
    RR -> SIN : <<create>> ServiceIN(booking)
    activate SIN
    SIN --> RR : ServiceIN
    deactivate SIN
    
    RR -> CUS : add_reserve_list(service)
    
    RR -> SIN : calculate_total()
