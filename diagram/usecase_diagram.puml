@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam backgroundColor #FEFEFE

skinparam usecase {
  BackgroundColor #FFFDE7
  BorderColor     #E6AC00
  FontSize        12
}
skinparam actor {
  BackgroundColor #E8F5E9
  BorderColor     #2E7D32
  FontSize        13
}
skinparam ArrowColor #555555

' ─── Actors ───────────────────────────────────────────────
actor  Customer        as C
actor  Staff           as S
actor "Payment System" as Pay

' ═══════════════════════════════════════════════════════════
rectangle "RhythmReserve System" {

  ' ── 1. Account Management ─────────────────────────────
  package "Account Management" {

    usecase "customer_register_request" as REG  #LightYellow
    usecase "pay_register"              as PR   #LightBlue
    usecase "confirm_register"          as CR   #LightYellow
    usecase "login"                     as LGN  #LightYellow
    usecase "logout"                    as LGT  #LightYellow
    usecase "edit_info"                 as EI   #LightYellow
    usecase "change_password"           as CHPW #LightYellow
    usecase "noti_send"                 as VN   #LightYellow

    C -- REG
    C -- LGN
    C -- LGT
    C -- EI
    C -- CHPW
    C -- VN

    REG ..> PR : <<include>>\n[Premium / Diamond]
    PR  ..> CR : <<include>>
  }

  ' ── 2. Room & Equipment Search ────────────────────────
  package "Room & Equipment Search" {

    usecase "get_available_room_slots"  as GAR #LightYellow
    usecase "get_available_equipment"   as GAE #LightYellow

    C -- GAR
    C -- GAE
  }

  ' ── 3. Room Reservation (ServiceIN) ──────────────────
  package "Room Reservation (ServiceIN)" {

    usecase "create_service_in"   as CSI  #LightBlue
    usecase "create_booking"      as CB   #LightYellow
    usecase "check_selected_eq"   as CSE  #LightYellow
    usecase "calculate_price"     as BCP  #LightYellow

    usecase "pay_service_in"      as PSI  #LightBlue
    usecase "calculate_total"     as SCT  #LightYellow
    usecase "get_tier_discount"   as ATD  #LightYellow
    usecase "get_discount"        as ACD  #LightYellow

    usecase "cancel_booking"      as CANC #LightBlue
    usecase "check_cancel_refund" as CCP  #LightYellow
    usecase "cancel_b"            as CNCL #LightYellow
    usecase "payment_refund"      as PREF #LightYellow

    C -- CSI
    C -- PSI
    C -- CANC

    CSI  ..> CB   : <<include>>
    CSI  ..> CSE  : <<include>>
    CB   ..> BCP  : <<include>>

    PSI  ..> SCT  : <<include>>
    PSI  ..> ATD  : <<include>>
    ACD  ..> PSI  : <<extend>>

    CANC ..> CCP  : <<include>>
    CANC ..> CNCL : <<include>>
    CNCL ..> PREF : <<include>>
  }

  ' ── 4. Check-in ───────────────────────────────────────
  package "Check-in" {

    usecase "check_in"               as CIN   #LightBlue
    usecase "update_timeslot_status" as UTS   #LightYellow
    usecase "set_service_out"        as CSOUT #LightYellow

    C -- CIN

    CIN ..> UTS   : <<include>>
    CIN ..> CSOUT : <<include>>
  }

  ' ── 5. ServiceOUT ─────────────────────────────────────
  package "ServiceOUT" {

    usecase "add_product_to_service_out"  as BUY #LightBlue
    usecase "get_service_out_summary"     as SOS #LightYellow
    usecase "add_product"                 as ADP #LightYellow

    C -- BUY
    C -- SOS

    BUY ..> ADP : <<include>>
  }

  ' ── 6. Checkout (ServiceOUT) ──────────────────────────
  package "Checkout (ServiceOUT)" {

    usecase "pay_service_out"       as PSO #LightBlue
    usecase "check_late_checkout"   as CLC #LightYellow
    usecase "check_damage_penalty"  as CDP #LightYellow
    usecase "calculate_total_price" as CTP #LightYellow
    usecase "add_points"            as AP  #LightYellow

    C -- PSO

    PSO ..> CLC : <<include>>
    PSO ..> CTP : <<include>>
    CDP ..> PSO : <<extend>>
    PSO ..> AP  : <<include>>
  }

  ' ── 7. Points & Coupon ────────────────────────────────
  package "Points & Coupon" {

    usecase "manual_redeem_coupon"  as MRC #LightBlue
    usecase "redeem_coupon"         as RC  #LightYellow
    usecase "get_my_coupons"        as GMC #LightYellow

    C -- MRC
    C -- GMC

    MRC ..> RC : <<include>>
  }

  ' ── 8. Staff Operations ───────────────────────────────
  package "Staff Operations" {

    usecase "customer_check_out"   as SCCO #LightBlue
    usecase "confirm_checkout"     as SCC  #LightYellow
    usecase "generate_report_data" as GDR  #LightYellow
    usecase "add_room"             as MR   #LightYellow
    usecase "add_equipment"        as ME   #LightYellow
    usecase "staff_register"       as MST  #LightYellow

    S -- SCCO
    S -- SCC
    S -- GDR
    S -- MR
    S -- ME
    S -- MST

    SCCO ..> CLC : <<include>>
    SCCO ..> CDP : <<extend>>
    SCC  ..> PSO : <<include>>
  }

  ' ── Payment System connections ────────────────────────
  PSI  --> Pay
  PSO  --> Pay
  PR   --> Pay
}

@enduml
