@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam backgroundColor #FEFEFE

skinparam usecase {
  BackgroundColor #FFFDE7
  BorderColor     #E6AC00
  FontSize        12
}
skinparam actor {
  BackgroundColor #E8F5E9
  BorderColor     #2E7D32
  FontSize        13
}
skinparam ArrowColor #555555
skinparam NoteBackgroundColor #F3E5F5
skinparam NoteBorderColor     #9C27B0

' ─── Actors ───────────────────────────────────────────────
actor  Customer        as C
actor  Staff           as S
actor "Payment System" as Pay

' ═══════════════════════════════════════════════════════════
rectangle "RhythmReserve System" {

  ' ── 1. Account Management ─────────────────────────────
  package "Account Management" {

    usecase "Register Account"    as REG  #LightYellow
    usecase "Pay Registration Fee" as PRF  #LightYellow
    usecase "Login"               as LGN  #LightYellow
    usecase "Logout"              as LGT  #LightYellow
    usecase "Manage Profile\n(email / phone / address)" as MP  #LightYellow
    usecase "Change Password"     as CHPW #LightYellow
    usecase "View Notifications"  as VN   #LightYellow

    C -- REG
    C -- LGN
    C -- LGT
    C -- MP
    C -- CHPW
    C -- VN

    REG  ..> PRF  : <<include>>\n[Premium / Diamond]
    CHPW ..> MP   : <<extend>>
  }

  ' ── 2. Room & Equipment Search ────────────────────────
  package "Room & Equipment Search" {

    usecase "Search Available Room Slots"  as SAR #LightYellow
    usecase "Filter by Date and Time"      as FDT #LightYellow
    usecase "Filter by Room Size"          as FRS #LightYellow
    usecase "Search Available Equipment"   as SAE #LightYellow

    C -- SAR
    C -- SAE

    SAR ..> FDT : <<include>>
    SAR ..> FRS : <<include>>
    SAE ..> FDT : <<include>>
  }

  ' ── 3. Room Reservation (Service_IN) ─────────────────
  package "Room Reservation  (Service_IN)" {

    usecase "Create Reservation\n(Service_IN)"   as CR  #LightBlue
    usecase "Select Available Room"              as SR  #LightYellow
    usecase "Select Time Slot"                   as STS #LightYellow
    usecase "Add Equipment to Booking"           as AEQ #LightYellow
    usecase "Check Equipment Quota"              as CEQ #LightYellow
    usecase "Calculate Booking Price\n(room rate × duration + eq rate)" as CBP #LightYellow

    usecase "Add Booking to Existing Service"    as ABS #LightBlue

    usecase "View Reservation Summary"           as VRS #LightYellow
    usecase "Apply Coupon Discount"              as ACD #LightYellow

    usecase "Checkout Reservation"               as CHK #LightBlue
    usecase "Apply Tier Discount\n(STD 0% / PRM 3% / DMN 5%)" as ATD #LightYellow
    usecase "Process Payment"                    as PP  #LightBlue

    usecase "Cancel Booking"                     as CB  #LightBlue
    usecase "Check Cancellation Policy\n(STD 24h / PRM 12h / DMN 6h)" as CCP #LightYellow
    usecase "Calculate Proportional Refund"      as CPR #LightYellow
    usecase "Refund Payment"                     as RP  #LightBlue

    C -- CR
    C -- ABS
    C -- VRS
    C -- CHK
    C -- CB

    CR  ..> SR  : <<include>>
    CR  ..> STS : <<include>>
    CR  ..> AEQ : <<include>>
    CR  ..> CEQ : <<include>>
    CR  ..> CBP : <<include>>

    ABS ..> SR  : <<include>>
    ABS ..> STS : <<include>>
    ABS ..> AEQ : <<include>>
    ABS ..> CEQ : <<include>>

    ACD ..> VRS : <<extend>>

    CHK ..> ATD : <<include>>
    ACD ..> CHK : <<extend>>
    CHK ..> PP  : <<include>>

    CB  ..> CCP : <<include>>
    CB  ..> CPR : <<include>>
    RP  ..> CB  : <<extend>>
    RP  ..> PP  : <<include>>
  }

  ' ── 4. Service_OUT  (Snacks & Penalty) ───────────────
  package "Service_OUT\n(Snacks & Penalty)" {

    usecase "Browse Snacks and Drinks"  as BSD #LightYellow
    usecase "Buy Snacks and Drinks"     as BUY #LightBlue
    usecase "Select Items"              as SI  #LightYellow

    usecase "View Penalties"            as VP  #LightYellow
    usecase "Pay Penalty"               as PAP #LightBlue

    C -- BSD
    C -- BUY
    C -- VP
    C -- PAP

    BUY ..> SI  : <<include>>
    BUY ..> PP  : <<include>>
    PAP ..> PP  : <<include>>
  }

  ' ── 5. Support ────────────────────────────────────────
  package "Support" {
    usecase "Report Room or\nEquipment Issue" as RI #LightYellow
    C -- RI
  }

  ' ── 6. Staff Operations ───────────────────────────────
  package "Staff Operations" {

    usecase "Staff Login"             as SL  #LightYellow
    usecase "View Booking Schedule"   as VBS #LightYellow

    usecase "Customer Check-in"       as CCI #LightBlue
    usecase "Verify Reservation"      as VR  #LightYellow
    usecase "Update Room/EQ Status"   as URS #LightYellow

    usecase "Customer Check-out"      as CCO #LightBlue
    usecase "Check Late Checkout\n(grace 15 min → LATE penalty)" as CLC #LightYellow
    usecase "Record Damage"           as RD  #LightBlue
    usecase "Create Penalty\n(LATE / DAMAGE / CANCEL_LATE / NO_SHOW)" as CPN #LightBlue
    usecase "Set to Maintenance"      as STM #LightYellow
    usecase "Confirm Checkout\n& Collect Payment" as CCP2 #LightYellow
    usecase "Update Daily Report"     as UDR #LightYellow

    usecase "Generate Daily Report"   as GDR #LightYellow
    usecase "View Penalty Breakdown"  as VPB #LightYellow

    usecase "Manage Rooms"      as MR   #LightYellow
    usecase "Manage Equipment"  as ME   #LightYellow
    usecase "Manage Products"   as MPR  #LightYellow
    usecase "Manage Pricing"    as MPRC #LightYellow
    usecase "Manage Coupons"    as MC   #LightYellow
    usecase "Manage Policies"   as MPOL #LightYellow

    S -- SL
    S -- VBS
    S -- CCI
    S -- CCO
    S -- CCP2
    S -- GDR
    S -- MR
    S -- ME
    S -- MPR
    S -- MPRC
    S -- MC
    S -- MPOL

    CCI  ..> VR  : <<include>>
    CCI  ..> URS : <<include>>

    CCO  ..> URS : <<include>>
    CCO  ..> CLC : <<include>>
    RD   ..> CCO : <<extend>>
    RD   ..> CPN : <<include>>
    RD   ..> STM : <<include>>

    CCP2 ..> PP  : <<include>>
    CCP2 ..> UDR : <<include>>

    GDR  ..> VPB : <<include>>
  }

  ' ── Payment System connection ─────────────────────────
  PP  --> Pay
  PRF --> Pay
  RP  --> Pay
}

@enduml