@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor User
actor Customer as C
actor Staff as S
actor "Payment System" as Pay

User <|-- Customer
User <|-- Staff

rectangle "RhythmReserve System" {

  package "Account Management" {
    (Register Account) #LightYellow
    C -- (Register Account)

    (Login) #LightYellow
    C -- (Login)

    (Logout) #LightYellow
    C -- (Logout) 

    (Manage Profile) #LightYellow
    C -- (Manage Profile)

    (Change Password) #LightYellow
    (Manage Profile) #LightYellow
    (Change Password) ..> (Manage Profile) : <<extend>>

    (View Notifications) #LightYellow
    C -- (View Notifications)

  }

  package "Room Reservation (Service_IN)" {
    (Search Available Rooms) #LightYellow
    C -- (Search Available Rooms)

    (Search Available Rooms) #LightYellow
    (Filter by Date and Time) #LightYellow
    (Search Available Rooms) ..> (Filter by Date and Time) : <<include>>

    (Search Available Rooms)#LightYellow
   (Filter by Room Size) #LightYellow
    (Search Available Rooms) ..> (Filter by Room Size) : <<include>>

    (Create Reservation) #LightBlue
    C -- (Create Reservation)

    (Create Reservation) #LightBlue
    (Select Room) #LightYellow
    (Create Reservation) ..> (Select Room) : <<include>>

    (Create Reservation) #LightBlue
    (Select Time Slot) #LightYellow
    (Create Reservation) ..> (Select Time Slot) : <<include>>

    (Create Reservation) #LightBlue
    (Add Equipment) #LightYellow
    (Create Reservation) ..> (Add Equipment) : <<include>>

    (Create Reservation) #LightBlue
   (Calculate Booking Price) #LightYellow
    (Create Reservation) ..> (Calculate Booking Price) : <<include>>

    (View Reservation Summary) #LightYellow
    C -- (View Reservation Summary)

    (Apply Coupon) #LightYellow
    (View Reservation Summary) #LightYellow
    (Apply Coupon) ..> (View Reservation Summary) : <<extend>>

    (Checkout Reservation) #LightBlue
    (Process Payment) #LightBlue
    C -- (Checkout Reservation)
    (Checkout Reservation) ..> (Process Payment) : <<include>>

    (Cancel Reservation) #LightBlue
    C -- (Cancel Reservation)
    (Check Cancellation Policy) #LightYellow
    (Cancel Reservation) ..> (Check Cancellation Policy) : <<include>>

    (Refund Payment) #LightBlue
    (Cancel Reservation) #LightBlue
    (Refund Payment) ..> (Cancel Reservation) : <<extend>>

  }

  package "Snacks and Penalty (Service_OUT)" {

    (Browse Snacks and Drinks) #LightYellow
    C -- (Browse Snacks and Drinks)

    (Buy Snacks and Drinks) #LightBlue
    C -- (Buy Snacks and Drinks)
    (Select Items) #LightYellow
    (Process Payment) #LightBlue
    (Buy Snacks and Drinks) ..> (Select Items) : <<include>>
    (Buy Snacks and Drinks) ..> (Process Payment) : <<include>>

    (View Penalties) #LightYellow
    C -- (View Penalties)
    (Pay Penalty) #LightBlue
    C -- (Pay Penalty)

    (Pay Penalty)#LightBlue
    (Process Payment) #LightBlue
    (Pay Penalty) ..> (Process Payment) : <<include>>

  }

  package "Support" {

    (Report Room or Equipment Issue) #LightYellow
    C -- (Report Room or Equipment Issue)

  }

  package "Staff Operations" {

    (Staff Login) #LightYellow
    S -- (Staff Login)

    (View Booking Schedule) #LightYellow
    S -- (View Booking Schedule)

    (Customer Check-in) #LightBlue
    S -- (Customer Check-in)

    (Verify Reservation)  #LightYellow
    (Update Room Status) #LightYellow
    (Customer Check-in) ..> (Verify Reservation) : <<include>>
    (Customer Check-in) ..> (Update Room Status) : <<include>>

    (Customer Check-out)#LightBlue
    S -- (Customer Check-out)
    (Customer Check-out) #LightBlue
    (Update Room Status) #LightYellow
    (Customer Check-out) ..> (Update Room Status) : <<include>>

    (Record Damage)#LightBlue
    (Customer Check-out) #LightBlue
    (Record Damage) ..> (Customer Check-out) : <<extend>>
    (Create Penalty) #LightBlue
    (Record Damage) #LightBlue
    (Create Penalty) ..> (Record Damage) : <<include>>

    (Manage Rooms) #LightYellow
    (Manage Equipment) #LightYellow
    (Manage Products) #LightYellow
    (Manage Pricing) #LightYellow
    (Manage Coupons) #LightYellow
    (Manage Policies) #LightYellow
    S -- (Manage Rooms)
    S -- (Manage Equipment)
    S -- (Manage Products)
    S -- (Manage Pricing)
    S -- (Manage Coupons)
    S -- (Manage Policies)

  }

  (Process Payment) #LightBlue
  (Process Payment) --> Pay

}

@enduml